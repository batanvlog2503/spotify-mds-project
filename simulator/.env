    # -------------------------------
    # Kafka Configuration
    # -------------------------------
    KAFKA_BOOTSTRAP_SERVERS=localhost:29092
    # đây là địa chỉ nhà của máy chủ kafka
    # host.docker.internal: đây la một cái tên đặc biệt giúp code python
    # chạy trong docker có thể nhìn thấy máy chủ kafka đang chạy ở máy thật
    #(localhost) của bạn
    #29092 là cổng port mà kafka đón nhận dữ liệu
    KAFKA_TOPIC=spotify-events
    # tên cái "hộp" chứa dữ liệu trên kafka. bạn đặt tên là spotify-events
    # thì sau này ở snowflake, bạn cũng  phải trỏ vào đúng cái hộp này để lấy dữ liệu
    # -------------------------------
    # Simulation Settings
    # -------------------------------
    USER_COUNT=20
    # số lượng người dùng giả lập
    EVENT_INTERVAL_SECONDS=1
    # tốc độ sinh dữ liệu , số 1 là cứ mỗi giây sẽ có 1 lượt  nghe ược
    # tạo ra. nếu bạn muốn nhanh hơn, hãy chỉnh thành 0.1
